{% render "overview_full", steps: steps, distance_km: distance_km, active_energy_kcal: active_energy_kcal, exercise_minutes: exercise_minutes, resting_heart_rate_bpm: resting_heart_rate_bpm, weight_kg: weight_kg, sleep: sleep, sleep_value: sleep_value %}
{% endcase %}
{% endif %}

