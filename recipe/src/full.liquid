{% assign view_style = trmnl.plugin_settings.custom_fields_values.view_style | default: "overview" %}
{% if schema_version and schema_version > 1 %}
<div class="layout layout--col layout--center">
  <span class="title title--small">Recipe Update Required</span>
  <span class="label label--gray">The app sent schema v{{ schema_version }}; this recipe renders v1</span>
</div>
{% else %}
{% case view_style %}
{% when "activity" %}
<div class="layout layout--col gap--space-between">
  <div class="grid grid--cols-3 gap--medium">
    {% render "activity_ring", value: active_energy_kcal, goal: goals.move_kcal, label: "Move", px: 140 %}
    {% render "activity_ring", value: exercise_minutes, goal: goals.exercise_minutes, label: "Exercise", px: 140 %}
    {% render "activity_ring", value: stand_hours, goal: goals.stand_hours, label: "Stand", px: 140 %}
  </div>

  <div class="divider"></div>

  {% if sleep %}
    {% capture sleep_value %}{% render "duration_hm", minutes: sleep.total_minutes %}{% endcapture %}
  {% endif %}
  <div class="grid grid--cols-5">
    {% render "stat_item", value: steps, label: "Steps", number: true, centered: true %}
    {% render "stat_item", value: sleep_value, label: "Sleep", centered: true %}
    {% render "stat_item", value: resting_heart_rate_bpm, label: "Resting HR (bpm)", centered: true %}
    {% render "stat_item", value: hrv_ms, label: "HRV (ms)", centered: true %}
    {% render "stat_item", value: vo2_max, label: "VO2 Max", centered: true %}
  </div>
</div>
{% else %}
<div class="layout layout--col gap--medium">
  <div class="grid grid--cols-3 gap--medium">
    {% render "stat_item", value: steps, label: "Steps", size: "large", number: true, big_label: true %}
    {% render "stat_item", value: distance_km, label: "Distance (km)", size: "large", big_label: true %}
    {% render "stat_item", value: active_energy_kcal, label: "Active Energy (kcal)", size: "large", number: true, big_label: true %}
    {% render "stat_item", value: exercise_minutes, label: "Exercise (min)", size: "large", big_label: true %}
    {% render "stat_item", value: resting_heart_rate_bpm, label: "Resting HR (bpm)", size: "large", big_label: true %}
    {% render "stat_item", value: weight_kg, label: "Weight (kg)", size: "large", big_label: true %}
  </div>

  <div class="divider"></div>

  {% if sleep %}
  {% capture sleep_value %}{% render "duration_hm", minutes: sleep.total_minutes %}{% endcapture %}
  {% if sleep.start and sleep.end %}{% capture sleep_sublabel %}{{ sleep.start }} – {{ sleep.end }}{% endcapture %}{% endif %}
  <div class="grid">
    <div class="col--span-4">
      {% render "stat_item", value: sleep_value, label: "Sleep", size: "large", big_label: true, sublabel: sleep_sublabel %}
    </div>
    <div class="col--span-8">
      {% render "sleep_stage_grid", sleep: sleep %}
    </div>
  </div>
  {% else %}
  <div class="flex flex--center">
    <span class="label label--gray">No sleep data</span>
  </div>
  {% endif %}
</div>
{% endcase %}
{% endif %}

{% render "app_title_bar", date: date %}
