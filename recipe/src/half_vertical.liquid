{% if schema_version and schema_version > 1 %}
<div class="layout layout--col layout--center">
  <span class="title title--small">Recipe Update Required</span>
  <span class="label label--gray">App schema v{{ schema_version }}; recipe renders v1</span>
</div>
{% else %}
<div class="layout layout--col gap">
  <div class="grid grid--cols-2 gap">
    {% render "stat_item", value: steps, label: "Steps", number: true %}
    {% render "stat_item", value: distance_km, label: "Distance (km)" %}
    {% render "stat_item", value: active_energy_kcal, label: "Energy (kcal)", number: true %}
    {% render "stat_item", value: exercise_minutes, label: "Exercise (min)" %}
    {% render "stat_item", value: resting_heart_rate_bpm, label: "Resting HR (bpm)" %}
    {% render "stat_item", value: weight_kg, label: "Weight (kg)" %}
  </div>

  <div class="divider"></div>

  {% if sleep %}
  {% capture sleep_value %}{% render "duration_hm", minutes: sleep.total_minutes %}{% endcapture %}
  {% capture sleep_sublabel %}Deep {{ sleep.deep_minutes | default: 0 }}m · REM {{ sleep.rem_minutes | default: 0 }}m{% endcapture %}
  {% render "stat_item", value: sleep_value, label: "Sleep", size: "medium", sublabel: sleep_sublabel %}
  {% else %}
  <span class="label label--small label--gray">No sleep data</span>
  {% endif %}
</div>
{% endif %}

{% render "app_title_bar", date: date %}
