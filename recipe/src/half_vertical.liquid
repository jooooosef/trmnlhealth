{% if schema_version and schema_version > 1 %}
<div class="layout layout--col layout--center">
  <span class="title title--small">Recipe Update Required</span>
  <span class="label label--gray">App schema v{{ schema_version }}; recipe renders v1</span>
</div>
{% else %}
<div class="layout layout--col gap">
  <div class="grid grid--cols-2 gap">
    <div class="item">
      <div class="meta"></div>
      <div class="content">
        <span class="value value--base value--tnums" data-value-type="number" data-fit-value="true">{{ steps | default: "–" }}</span>
        <span class="label label--small">Steps</span>
      </div>
    </div>
    <div class="item">
      <div class="meta"></div>
      <div class="content">
        <span class="value value--base value--tnums" data-fit-value="true">{{ distance_km | default: "–" }}</span>
        <span class="label label--small">Distance (km)</span>
      </div>
    </div>
    <div class="item">
      <div class="meta"></div>
      <div class="content">
        <span class="value value--base value--tnums" data-value-type="number" data-fit-value="true">{{ active_energy_kcal | default: "–" }}</span>
        <span class="label label--small">Energy (kcal)</span>
      </div>
    </div>
    <div class="item">
      <div class="meta"></div>
      <div class="content">
        <span class="value value--base value--tnums" data-fit-value="true">{{ exercise_minutes | default: "–" }}</span>
        <span class="label label--small">Exercise (min)</span>
      </div>
    </div>
    <div class="item">
      <div class="meta"></div>
      <div class="content">
        <span class="value value--base value--tnums" data-fit-value="true">{{ resting_heart_rate_bpm | default: "–" }}</span>
        <span class="label label--small">Resting HR (bpm)</span>
      </div>
    </div>
    <div class="item">
      <div class="meta"></div>
      <div class="content">
        <span class="value value--base value--tnums" data-fit-value="true">{{ weight_kg | default: "–" }}</span>
        <span class="label label--small">Weight (kg)</span>
      </div>
    </div>
  </div>

  <div class="divider"></div>

  {% if sleep %}
  <div class="item">
    <div class="meta"></div>
    <div class="content">
      <span class="value value--medium value--tnums" data-fit-value="true">{{ sleep.total_minutes | default: 0 | divided_by: 60 }}h {{ sleep.total_minutes | default: 0 | modulo: 60 }}m</span>
      <span class="label label--small">Sleep</span>
      <span class="label label--small label--gray">Deep {{ sleep.deep_minutes | default: 0 }}m · REM {{ sleep.rem_minutes | default: 0 }}m</span>
    </div>
  </div>
  {% else %}
  <span class="label label--small label--gray">No sleep data</span>
  {% endif %}
</div>
{% endif %}

<div class="title_bar">
  <img class="image image-stroke" src="data:image/svg+xml;base64,{{ svg_logo | base64_encode }}" />
  <span class="title">Apple Health</span>
  <span class="instance">{{ date }}</span>
</div>
